show_model <- function(model_name) {
sub <- df_all[df_all$model == model_name, ]
result <- sub %>%
group_by(problem, condition, response) %>%
summarise(n = n(), .groups = "drop") %>%
pivot_wider(names_from = condition, values_from = n, values_fill = 0) %>%
arrange(problem, response)
View(result, title = model_name)
return(result)
}
show_model(claude)
show_model <- function(model_name) {
sub <- df_all[df_all$model == model_name, ]
# Alle Kombinationen sicherstellen (auch 0-Zellen)
all_combos <- expand.grid(
problem = unique(sub$problem),
condition = unique(sub$condition),
response = c("A", "B"),
stringsAsFactors = FALSE
)
# Nur gültige Problem-Condition-Paare behalten
valid <- unique(sub[, c("problem", "condition")])
all_combos <- merge(all_combos, valid)
counts <- sub %>%
group_by(problem, condition, response) %>%
summarise(n = n(), .groups = "drop")
full <- merge(all_combos, counts, all.x = TRUE)
full$n[is.na(full$n)] <- 0
# Spaltenname = Problem + Condition
full$col <- paste0(full$problem, "\n", full$condition)
result <- full %>%
select(response, col, n) %>%
pivot_wider(names_from = col, values_from = n, values_fill = 0) %>%
arrange(response)
View(result, title = model_name)
return(result)
}
show_model(claude)
install.packages("gt")
library(gt)
library(gt)
show_model <- function(model_name) {
sub <- df_all[df_all$model == model_name, ]
all_combos <- expand.grid(
problem = unique(sub$problem),
condition = unique(sub$condition),
response = c("A", "B"),
stringsAsFactors = FALSE
)
valid <- unique(sub[, c("problem", "condition")])
all_combos <- merge(all_combos, valid)
counts <- sub %>%
group_by(problem, condition, response) %>%
summarise(n = n(), .groups = "drop")
full <- merge(all_combos, counts, all.x = TRUE)
full$n[is.na(full$n)] <- 0
# Spaltenname = problem__condition (trennbar)
full$col <- paste0(full$problem, "__", full$condition)
result <- full %>%
select(response, col, n) %>%
pivot_wider(names_from = col, values_from = n, values_fill = 0) %>%
arrange(response)
# GT Tabelle mit gruppierten Spalten
tbl <- gt(result)
for (p in unique(full$problem)) {
cols <- grep(paste0("^", p, "__"), names(result), value = TRUE)
# Condition-Namen als Spaltenlabel
new_labels <- setNames(
gsub(paste0(p, "__"), "", cols),
cols
)
tbl <- tbl %>%
cols_label(!!!new_labels) %>%
tab_spanner(label = p, columns = all_of(cols))
}
tbl <- tbl %>% tab_header(title = model_name)
print(tbl)
return(tbl)
}
show_model(claude)
