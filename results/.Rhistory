show_model <- function(model_name) {
cat("\n===", model_name, "===\n")
sub <- df_all[df_all$model == model_name, ]
summary <- sub %>%
group_by(problem, condition, response) %>%
summarise(n = n(), .groups = "drop") %>%
pivot_wider(names_from = response, values_from = n, values_fill = 0) %>%
mutate(total = A + B, prop_A = round(A / total, 3))
print(kable(summary, format = "simple"))
}
