show_model <- function(model_name) {
cat("\n===", model_name, "===\n\n")
problems <- unique(df_all$problem)
for (p in problems) {
cat("\n---", p, "---\n")
sub <- df_all[df_all$model == model_name & df_all$problem == p, ]
print(table(sub$response, sub$condition))
cat("\n")
}
}
